---
// Bronze L-shaped corner brackets used to frame imagery.
// Drawn as a single SVG so GSAP can animate stroke-dashoffset on each leg.

interface Props {
  inset?: string;     // distance from edge of parent
  size?: string;      // length of each leg
  color?: string;
  stroke?: string;
}

const {
  inset = "1.75rem",
  size = "4.5rem",
  color = "var(--bronze)",
  stroke = "1px",
} = Astro.props;
---

<div class="brackets" style={`--inset:${inset};--size:${size};--c:${color};--w:${stroke};`} aria-hidden="true">
  <span class="b b--tl"></span>
  <span class="b b--tr"></span>
  <span class="b b--bl"></span>
  <span class="b b--br"></span>
</div>

<style>
  .brackets {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .b {
    position: absolute;
    width: var(--size);
    height: var(--size);
  }
  .b::before,
  .b::after {
    content: "";
    position: absolute;
    background: var(--c);
    transform-origin: top left;
  }
  /* Horizontal leg */
  .b::before {
    left: 0;
    width: var(--size);
    height: var(--w);
  }
  /* Vertical leg */
  .b::after {
    top: 0;
    width: var(--w);
    height: var(--size);
  }
  .b--tl { top: var(--inset); left: var(--inset); }
  .b--tr { top: var(--inset); right: var(--inset); transform: scaleX(-1); }
  .b--bl { bottom: var(--inset); left: var(--inset); transform: scaleY(-1); }
  .b--br { bottom: var(--inset); right: var(--inset); transform: scale(-1); }
</style>
