---
const projects = [
  {
    name: "BUNA TETU",
    kind: "Cocktail Bar · Athens",
    year: "2024",
    img: "https://images.unsplash.com/photo-1572116469696-31de0f17cc34?auto=format&fit=crop&w=1400&q=80",
  },
  {
    name: "ΚΤΗΡΙΟ ΟΤΕ",
    kind: "Commercial Building",
    year: "2023",
    img: "https://images.unsplash.com/photo-1486325212027-8081e485255e?auto=format&fit=crop&w=1400&q=80",
  },
  {
    name: "MEDITERRANEAN HOTEL",
    kind: "Hospitality · Crete",
    year: "2023",
    img: "https://images.unsplash.com/photo-1564501049412-61c2a3083791?auto=format&fit=crop&w=1400&q=80",
  },
  {
    name: "MAROUSI RESIDENCE",
    kind: "Private Residence",
    year: "2022",
    img: "https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&w=1400&q=80",
  },
  {
    name: "AGORA LOFT",
    kind: "Renovation · Athens",
    year: "2022",
    img: "https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=1400&q=80",
  },
  {
    name: "OLEA HOUSE",
    kind: "Residential · Kifisia",
    year: "2021",
    img: "https://images.unsplash.com/photo-1615874959474-d609969a20ed?auto=format&fit=crop&w=1400&q=80",
  },
];
---

<section id="projects" class="projects section">
  <header class="projects-head">
    <span class="eyebrow" data-reveal>
      Portfolio <span class="eyebrow-line"></span>
    </span>
    <h2 class="section-title" data-split-title>
      <span class="line">ΤΑ ΕΡΓΑ ΜΑΣ</span>
    </h2>
    <p class="projects-lede body-copy" data-reveal>
      Έξι έργα που μεταφράζουν το όραμα σε χώρο — από εμπορικά κτήρια και
      ξενοδοχεία μέχρι ανακαινίσεις κατοικιών.
    </p>
  </header>

  <div class="projects-grid">
    {projects.map((p, i) => (
      <a class="tile" href="#" data-tile style={`--idx:${i}`}>
        <figure class="tile-figure">
          <img src={p.img} alt={p.name} loading="lazy" decoding="async" />
          <span class="tile-veil"></span>
          <span class="tile-num">{String(i + 1).padStart(2, "0")}</span>
        </figure>
        <div class="tile-meta">
          <span class="tile-eyebrow">{p.kind} · {p.year}</span>
          <h3 class="tile-name">{p.name}</h3>
          <span class="tile-cta">
            <span>VIEW PROJECT</span>
            <svg viewBox="0 0 24 8" width="22" height="8" aria-hidden="true">
              <line x1="0" y1="4" x2="20" y2="4" stroke="currentColor" stroke-width="1"/>
              <polyline points="16,1 20,4 16,7" fill="none" stroke="currentColor" stroke-width="1"/>
            </svg>
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="projects-cta" data-reveal>
    <a class="btn-outline is-dark" href="#">ΟΛΑ ΤΑ ΕΡΓΑ</a>
  </div>
</section>

<style>
  .projects-head {
    max-width: var(--content-max);
    margin: 0 auto clamp(3rem, 6vw, 4.5rem);
  }
  .projects-head .eyebrow { margin-bottom: 1.5rem; }
  .projects-lede { max-width: 32rem; }

  .projects-grid {
    max-width: var(--content-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(1.25rem, 2.5vw, 2rem) clamp(1.25rem, 2.5vw, 2rem);
  }

  /* Asymmetric editorial layout — escapes the standard 3-up grid */
  .tile { grid-column: span 6; }
  .tile:nth-child(3n+1) { grid-column: span 7; }
  .tile:nth-child(3n+2) { grid-column: span 5; }
  .tile:nth-child(3n+3) { grid-column: span 12; }

  @media (max-width: 1024px) {
    .tile,
    .tile:nth-child(3n+1),
    .tile:nth-child(3n+2),
    .tile:nth-child(3n+3) { grid-column: span 12; }
  }

  /* ---- Single tile ---- */
  .tile {
    display: block;
    position: relative;
    color: var(--ink);
    text-decoration: none;
  }
  .tile-figure {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: var(--ink);
  }
  .tile:nth-child(3n+3) .tile-figure { aspect-ratio: 21 / 9; }
  .tile:nth-child(3n+2) .tile-figure { aspect-ratio: 4 / 5; }

  .tile-figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.04);
    transition: transform 2s var(--ease-arch), filter 1s var(--ease-arch);
    filter: saturate(0.9) contrast(1.04);
  }
  .tile-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 50%, rgba(0,0,0,0.55) 100%);
    transition: background 0.6s var(--ease-arch);
  }
  .tile:hover .tile-figure img { transform: scale(1.0); filter: saturate(1.05) contrast(1.04); }
  .tile:hover .tile-veil {
    background: linear-gradient(180deg, rgba(39,39,39,0) 35%, rgba(39,39,39,0.78) 100%);
  }

  .tile-num {
    position: absolute;
    top: 1.1rem; left: 1.25rem;
    font-family: var(--font-display);
    font-size: 0.5625rem;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--bronze);
    background: rgba(0,0,0,0.45);
    padding: 0.45rem 0.6rem;
    text-transform: uppercase;
  }

  .tile-meta {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .tile-eyebrow {
    font-family: var(--font-display);
    font-size: 0.6rem;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--bronze);
    text-transform: uppercase;
  }
  .tile-name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.05rem, 1.6vw, 1.4rem);
    letter-spacing: var(--tracking-section);
    color: var(--ink);
    text-transform: uppercase;
    transition: color 0.4s var(--ease-arch);
  }
  .tile:hover .tile-name { color: var(--bronze); }

  .tile-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    margin-top: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.5625rem;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--ink);
    opacity: 0.55;
    transition: opacity 0.4s var(--ease-arch), color 0.4s var(--ease-arch), transform 0.5s var(--ease-arch);
  }
  .tile:hover .tile-cta { opacity: 1; color: var(--bronze); transform: translateX(4px); }

  .projects-cta {
    max-width: var(--content-max);
    margin: clamp(3rem, 5vw, 4.5rem) auto 0;
    text-align: center;
  }
</style>
