---
import Brackets from "./Brackets.astro";

// Photographic hero — moody industrial loft.
const heroImg =
  "https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1900&q=80";
---

<section id="hero" class="hero" data-hero>
  <div class="hero-image" data-hero-image>
    <img
      src={heroImg}
      alt="Industrial loft interior with exposed brick, concrete ceiling, dark steel and warm lamplight"
      loading="eager"
      decoding="async"
    />
    <div class="hero-veil"></div>
  </div>

  <Brackets inset="2.5rem" size="6rem" stroke="1px" />

  <div class="hero-content">
    <span class="hero-eyebrow" data-reveal>
      <span class="line"></span>
      <span>Crafting Spaces · Since 2014</span>
    </span>

    <h1 class="hero-title" data-split-title>
      <span class="line">INNOVATE</span>
      <span class="line">CONSTRUCTION</span>
      <span class="line">&amp; RENOVATION</span>
      <span class="line"><em>in</em> GREECE</span>
    </h1>

    <p class="hero-lede" data-reveal>
      59 ST — Crafting spaces with precision, innovation, and style.<br />
      We specialize in transforming your visions into reality.
    </p>

    <div class="hero-actions" data-reveal>
      <button class="btn-outline">ENG · ΕΛ</button>
      <a class="hero-scroll" href="#about" aria-label="Scroll to next section">
        <span>SCROLL</span>
        <svg viewBox="0 0 24 36" width="14" height="22" aria-hidden="true">
          <rect x="0.5" y="0.5" width="23" height="35" rx="11.5" fill="none" stroke="currentColor" stroke-width="1"/>
          <circle class="dot" cx="12" cy="10" r="1.4" fill="currentColor"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Bottom-right photo credit / location -->
  <div class="hero-meta">
    <span>059°</span><span class="sep"></span><span>Marathonodromou 59, Marousi</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: var(--black);
    color: var(--canvas);
    display: flex;
    align-items: center;
    padding: clamp(3.5rem, 8vw, 7rem) clamp(2rem, 6vw, 6rem);
  }

  .hero-image {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.18);          /* GSAP releases to 1.0 over the load */
    filter: contrast(1.05) saturate(0.85) brightness(0.78);
  }
  .hero-veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.18) 55%, rgba(0,0,0,0.05) 100%),
      linear-gradient(0deg, rgba(0,0,0,0.45), rgba(0,0,0,0.0) 35%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 38rem;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    font-family: var(--font-display);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--bronze);
    text-transform: uppercase;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }
  .hero-eyebrow .line {
    width: 3rem;
    height: 1px;
    background: var(--bronze);
    transform-origin: left center;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 4.25rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-hero);
    text-transform: uppercase;
    color: var(--canvas);
    margin: 0 0 clamp(1.75rem, 3vw, 2.5rem) 0;
  }
  .hero-title .line {
    display: block;
    overflow: hidden;
  }
  .hero-title em {
    font-style: italic;
    font-weight: 300;
    letter-spacing: 0.5rem;
    color: var(--bronze);
  }

  .hero-lede {
    max-width: 30rem;
    font-size: 1.05rem;
    line-height: 1.85;
    color: rgba(255,255,255,0.82);
    margin: 0 0 clamp(2rem, 4vw, 3rem) 0;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .hero-scroll {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-display);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--canvas);
    opacity: 0.75;
    transition: opacity 0.4s var(--ease-arch);
  }
  .hero-scroll:hover { opacity: 1; }
  .hero-scroll svg { color: var(--bronze); }
  .hero-scroll .dot {
    animation: scroll-dot 2.4s var(--ease-arch) infinite;
  }
  @keyframes scroll-dot {
    0%   { transform: translateY(0);     opacity: 1;  }
    50%  { transform: translateY(14px);  opacity: 0.2; }
    100% { transform: translateY(0);     opacity: 1;  }
  }

  .hero-meta {
    position: absolute;
    z-index: 2;
    right: clamp(2.5rem, 6vw, 6rem);
    bottom: clamp(2rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-display);
    font-size: 0.5625rem;
    letter-spacing: var(--tracking-eyebrow);
    color: rgba(255,255,255,0.62);
    text-transform: uppercase;
  }
  .hero-meta .sep {
    width: 1.75rem;
    height: 1px;
    background: var(--bronze);
    opacity: 0.7;
  }

  @media (max-width: 900px) {
    .hero { min-height: auto; padding-top: 5rem; padding-bottom: 5rem; }
    .hero-meta { display: none; }
  }
</style>
