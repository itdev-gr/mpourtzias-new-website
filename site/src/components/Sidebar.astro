---
const items = [
  { label: "ΑΡΧΙΚΗ",       href: "#hero" },
  { label: "ΕΤΑΙΡΕΙΑ",     href: "#about" },
  { label: "ΤΑ ΕΡΓΑ ΜΑΣ",  href: "#projects" },
  { label: "ΥΠΗΡΕΣΙΕΣ",    href: "#services" },
  { label: "BLOG",         href: "#news" },
  { label: "ΕΠΙΚΟΙΝΩΝΙΑ",  href: "#contact" },
];
---

<header class="topbar" data-rail>
  <a href="#hero" class="brand" aria-label="59ST ConstrAction — home">
    <svg
      class="brand-mark"
      viewBox="0 0 220 110"
      role="img"
      aria-hidden="true"
    >
      <g stroke="var(--bronze)" stroke-width="1.4" fill="none" stroke-linejoin="miter" stroke-linecap="square">
        <path d="M115 10 L115 32 L130 32 L130 14 L150 14 L150 36 L165 36 L165 22 L182 22 L182 44 L160 44" />
        <path d="M165 22 L165 44" />
        <path d="M150 36 L150 44" />
        <path d="M130 14 L130 32" />
        <text x="118" y="28" font-family="Oswald, sans-serif" font-size="9" fill="var(--bronze)" letter-spacing="1">59 ST</text>
      </g>
    </svg>
    <span class="brand-block">
      <span class="brand-word"><em>Constr</em><strong>Actio</strong><em>N</em></span>
      <span class="brand-tag">
        <span>ΤΕΧΝΙΚΗ</span><span class="dot">·</span><span>ΕΤΑΙΡΕΙΑ</span>
      </span>
    </span>
  </a>

  <nav class="topbar-nav" aria-label="Primary">
    <ul>
      {items.map((it, i) => (
        <li style={`--i:${i}`}><a href={it.href} data-nav-link>{it.label}</a></li>
      ))}
    </ul>
  </nav>

  <div class="topbar-end">
    <a class="topbar-social" href="https://instagram.com" aria-label="Instagram" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="0.2" ry="0.2" fill="none" stroke="currentColor" stroke-width="1.2"/>
        <circle cx="12" cy="12" r="4.4" fill="none" stroke="currentColor" stroke-width="1.2"/>
        <circle cx="17.4" cy="6.6" r="0.9" fill="currentColor"/>
      </svg>
    </a>
    <a class="topbar-cta" href="#contact">
      <span>ENQUIRE</span>
      <span class="arrow">→</span>
    </a>
    <button class="topbar-burger" aria-label="Open menu" data-burger>
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 30;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.5rem);
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(10px) saturate(1.05);
    -webkit-backdrop-filter: blur(10px) saturate(1.05);
    border-bottom: 1px solid rgba(0,0,0,0.06);
    padding: 0.85rem clamp(1.25rem, 4vw, 3rem);
  }

  /* ---- Brand ---- */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }
  .brand-mark {
    width: 56px;
    height: auto;
    display: block;
    margin-top: -2px;
  }
  .brand-block {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand-word {
    display: block;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.55rem;
    letter-spacing: -0.4px;
    color: var(--bronze);
    line-height: 1;
  }
  .brand-word em { font-style: normal; font-weight: 300; }
  .brand-word strong { font-weight: 500; color: var(--bronze); }
  .brand-tag {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.32rem;
    color: var(--bronze);
    font-family: var(--font-display);
    font-size: 0.5rem;
    letter-spacing: 0.4rem;
    text-transform: uppercase;
  }
  .brand-tag .dot { opacity: 0.55; }

  /* ---- Nav ---- */
  .topbar-nav {
    justify-self: center;
  }
  .topbar-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: clamp(1.1rem, 2.4vw, 2.25rem);
  }
  .topbar-nav a {
    position: relative;
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.78rem;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
    color: var(--ink);
    padding: 0.4rem 0;
    white-space: nowrap;
    transition: color 0.4s var(--ease-arch), letter-spacing 0.5s var(--ease-arch);
  }
  .topbar-nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1px;
    background: var(--bronze);
    transition: width 0.55s var(--ease-arch);
  }
  .topbar-nav a:hover {
    color: var(--bronze);
    letter-spacing: 0.25rem;
  }
  .topbar-nav a:hover::after { width: 100%; }

  /* ---- End cluster ---- */
  .topbar-end {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }

  .topbar-social {
    color: var(--ink);
    padding: 0.55rem;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 50%;
    transition: color 0.4s var(--ease-arch), border-color 0.4s var(--ease-arch), transform 0.5s var(--ease-arch);
    display: inline-flex;
  }
  .topbar-social:hover {
    color: var(--bronze);
    border-color: var(--bronze);
    transform: rotate(8deg);
  }

  .topbar-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--ink);
    padding: 0.85rem 1.25rem;
    border: 1px solid var(--ink);
    transition: background-color 0.4s var(--ease-arch), color 0.4s var(--ease-arch), letter-spacing 0.5s var(--ease-arch);
  }
  .topbar-cta:hover {
    background: var(--ink);
    color: var(--canvas);
    letter-spacing: 0.65rem;
  }
  .topbar-cta .arrow {
    color: var(--bronze);
    transition: transform 0.4s var(--ease-arch);
  }
  .topbar-cta:hover .arrow { transform: translateX(3px); }

  .topbar-burger {
    display: none;
    width: 36px;
    height: 36px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    cursor: pointer;
    background: transparent;
    border: 1px solid rgba(0,0,0,0.1);
  }
  .topbar-burger span {
    display: block;
    width: 18px;
    height: 1px;
    background: var(--ink);
  }

  /* ---- Responsive ---- */
  @media (max-width: 1100px) {
    .topbar-nav a { font-size: 0.72rem; letter-spacing: 0.16rem; }
    .topbar-nav ul { gap: 1.2rem; }
    .topbar-cta { display: none; }
  }
  @media (max-width: 860px) {
    .topbar { grid-template-columns: 1fr auto; padding: 0.75rem 1.25rem; }
    .brand-mark { width: 44px; }
    .brand-word { font-size: 1.25rem; }
    .topbar-nav {
      grid-column: 1 / -1;
      justify-self: stretch;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.5s var(--ease-arch);
    }
    .topbar-nav.is-open { max-height: 480px; }
    .topbar-nav ul {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.85rem;
      padding: 1rem 0 0.5rem;
      border-top: 1px solid rgba(0,0,0,0.06);
      margin-top: 0.6rem;
    }
    .topbar-burger { display: inline-flex; }
    .topbar-social { display: none; }
  }
</style>

<script>
  const burger = document.querySelector<HTMLButtonElement>("[data-burger]");
  const nav = document.querySelector<HTMLElement>(".topbar-nav");
  burger?.addEventListener("click", () => {
    nav?.classList.toggle("is-open");
  });
  // Auto-close on link click (mobile)
  nav?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => nav?.classList.remove("is-open")),
  );
</script>
